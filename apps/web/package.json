{
  "name": "@tsudolio/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev --hostname 0.0.0.0",
    "build": "prisma generate && next build",
    "lint": "prisma generate && eslint . --max-warnings=0",
    "typecheck": "prisma generate && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.3.0",
    "lucide-react": "1.14.0",
    "next": "16.2.6",
    "nodemailer": "8.0.7",
    "pg": "8.20.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@types/node": "25.6.2",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "prisma": "7.8.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
